APP_NAME="Escuela Aviación RAC141"
APP_URL=https://tudominio.com
APP_TIMEZONE=America/Bogota
APP_LOCALE=es

# PRODUCCIÓN: Cambiar a production y false
APP_ENV=production
APP_KEY=
APP_DEBUG=false

# Base de datos — rellenar con credenciales del cPanel
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=nombre_base_datos
DB_USERNAME=usuario_db
DB_PASSWORD=password_seguro

# Sanctum — dominio del frontend en producción
SANCTUM_STATEFUL_DOMAINS=tudominio.com,www.tudominio.com

# Mail (opcional)
MAIL_MAILER=smtp
MAIL_HOST=smtp.tudominio.com
MAIL_PORT=465
MAIL_USERNAME=noreply@tudominio.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@tudominio.com
MAIL_FROM_NAME="${APP_NAME}"
